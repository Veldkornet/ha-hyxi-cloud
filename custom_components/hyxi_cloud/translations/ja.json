{
  "config": {
    "step": {
      "user": {
        "title": "HYXI Cloudに接続",
        "description": "**開発者API資格情報 (AK/SK)**を入力してください。これらは[HYXIPOWER開発者プラットフォーム]({link})で作成できます。\n\n**注意:** 別途開発者アカウントが必要です。開発者用メールアドレスがアプリ用メールアドレスと異なる場合は、まずアプリから開発者用メールアドレスに**発電所を共有**する必要があります。",
        "data": {
          "access_key": "アクセスキー (AK)",
          "secret_key": "シークレットキー (SK)"
        }
      },
      "reauth_confirm": {
        "title": "HYXI Cloudの再認証",
        "description": "アクセスキーまたはシークレットキーが無効です。ソーラー監視を再開するには、新しい資格情報を入力してください。これらは[HYXIPOWER開発者プラットフォーム]({link})で見つけることができます。",
        "data": {
          "access_key": "アクセスキー (AK)",
          "secret_key": "シークレットキー (SK)"
        }
      }
    },
    "error": {
      "cannot_connect": "HYXIサーバーへの接続に失敗しました",
      "invalid_auth": "アクセスキーまたはシークレットキーが無効です",
      "unknown": "予期しないエラーが発生しました",
      "no_devices": "プラントまたはデバイスが見つかりません。開発者用メールアドレスがアプリ用メールアドレスと異なる場合は、まずアプリから開発者用メールアドレスにプラントを共有する必要があります。"
    },
    "abort": {
      "already_configured": "このHYXIアカウントは既に設定されています。",
      "reauth_successful": "再認証に成功しました"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "HYXIシステム設定",
        "description": "統合がHYXI Cloudと通信する方法を調整します。\n\n誤検知されたVPP制御（例：通常のworkMode 16）により操作がロックされている場合は、**Override VPP Lock**にチェックを入れて復旧させてください。\n\n---",
        "data": {
          "update_interval": "ポーリング間隔 (1-60分, デフォルト: 5)",
          "back_discovery": "アラーム経由の検出を有効にする (高度)",
          "enable_battery_control": "デバイス制御と保護を有効にする",
          "enable_energy_manager": "エネルギーマネージャー スタンドアロンを有効にする (ベータ)",
          "enable_realtime_push": "リアルタイムWebhookプッシュを有効にする",
          "realtime_push_rate": "プッシュ更新頻度 (ミリ秒, 範囲: 5000-3600000)",
          "realtime_push_url": "カスタムコールバックURL (オプション, 動的デフォルト)"
        }
      },
      "energy_manager": {
        "title": "エネルギーマネージャー",
        "description": "太陽光発電量、系統メーター、予測データに基づいてバッテリー使用を最適化するようにエネルギーマネージャーを設定します。",
        "data": {
          "em_p1_entity": "P1スマートメーター (電力センサー)",
          "em_forecast_entity": "本日の残り太陽光予測 (オプション)",
